{
  "name": "vpr",
  "description": "A (versioned) package release tool",
  "version": "1.4.6",
  "author": "Loren Segal",
  "license": "MIT",
  "repository": "lsegal/vpr",
  "homepage": "https://github.com/lsegal/vpr",
  "bugs": "https://github.com/lsegal/vpr/issues",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "vpr": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "adm-zip": "^0.5.17",
    "cli-color": "^2.0.4",
    "commander": "^14.0.3",
    "debug": "^4.4.3",
    "execa": "^9.6.1",
    "inquirer": "^13.4.1",
    "ora": "^9.3.0",
    "recursive-copy": "^2.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/adm-zip": "^0.5.8",
    "@types/cli-color": "^2.0.6",
    "@types/debug": "^4.1.13",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^2"
  },
  "resolutions": {
    "jackspeak": "2.1.1",
    "esbuild": "0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "tsup src/index.ts --sourcemap inline --format esm --dts --clean",
    "lint": "biome lint . --diagnostic-level=error && tsc",
    "posttest": "pnpm lint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "package": "tsx src/index.ts run -f pnpm package:stage",
    "package:stage": "pnpm install && tsx scripts/package.ts",
    "release": "tsx src/index.ts run -c pnpm release:stage && git pull",
    "release:stage": "pnpm install && tsx scripts/release.ts",
    "release:major": "cross-env VERSION=major pnpm package && pnpm release",
    "release:minor": "cross-env VERSION=minor pnpm package && pnpm release",
    "release:patch": "cross-env VERSION=patch pnpm package && pnpm release"
  },
  "types": "dist/index.d.ts"
}
